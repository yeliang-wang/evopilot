{
  "openapi": "3.1.0",
  "info": {
    "title": "EvoPilot API",
    "version": "1.0.0"
  },
  "paths": {
    "/health": {
      "get": {
        "summary": "健康检查",
        "responses": {
          "200": {
            "description": "服务已启动"
          }
        }
      }
    },
    "/ready": {
      "get": {
        "summary": "就绪检查",
        "responses": {
          "200": {
            "description": "存储已就绪"
          }
        }
      }
    },
    "/api/v1/summary": {
      "get": {
        "summary": "控制台汇总",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "responses": {
          "200": {
            "description": "汇总"
          },
          "401": {
            "description": "未授权"
          }
        }
      }
    },
    "/api/v1/profiles": {
      "get": {
        "summary": "列出项目画像",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "responses": {
          "200": {
            "description": "项目画像"
          }
        }
      }
    },
    "/api/v1/rules": {
      "get": {
        "summary": "列出用户规则",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "responses": {
          "200": {
            "description": "Dashboard 用户视角的自然语言规则"
          },
          "401": {
            "description": "未授权"
          },
          "403": {
            "description": "需要只读或更高角色"
          }
        }
      }
    },
    "/api/v1/evaluation-datasets": {
      "get": {
        "summary": "列出评测集",
        "description": "返回由 Trace、Log、Tool Call、Prompt Version、RAG Context、Cost、Latency 和用户反馈沉淀出的 Eval Dataset / Regression Suite，用于 Dashboard 多选形成机会点。",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "responses": {
          "200": {
            "description": "评测集列表"
          },
          "401": {
            "description": "未授权"
          },
          "403": {
            "description": "需要只读或更高角色"
          }
        }
      }
    },
    "/api/v1/opportunity-drafts": {
      "post": {
        "summary": "由评测集形成机会点草稿",
        "description": "Dashboard 选择一个或多个评测集后，生成机会点草稿和可编辑 Markdown 进化方案。",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "responses": {
          "201": {
            "description": "机会点草稿已生成"
          },
          "400": {
            "description": "必须选择评测集"
          },
          "401": {
            "description": "未授权"
          },
          "403": {
            "description": "需要操作员或更高角色"
          }
        }
      }
    },
    "/api/v1/projects": {
      "get": {
        "summary": "列出项目",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "responses": {
          "200": {
            "description": "项目列表"
          }
        }
      },
      "post": {
        "summary": "注册项目",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "responses": {
          "201": {
            "description": "项目已创建"
          },
          "403": {
            "description": "需要管理员角色"
          }
        }
      }
    },
    "/api/v1/connectors/jenkins": {
      "get": {
        "summary": "列出外部 Jenkins CI/CD 连接器配置",

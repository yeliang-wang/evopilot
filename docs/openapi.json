          {
            "bearerAuth": []
          }
        ],
        "responses": {
          "200": {
            "description": "执行图列表"
          }
        }
      },
      "post": {
        "summary": "创建或更新 Loop Runtime 执行图",
        "description": "定义 LLM、code-upgrader、CI、validator、approval、release-action 等 executor 节点及依赖关系。",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "responses": {
          "201": {
            "description": "执行图已保存"
          },
          "403": {

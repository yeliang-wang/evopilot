    "/api/v1/evidence/evaluations": {
      "post": {
        "summary": "评测结果证据接入",
        "description": "接收外部评测系统、语义回归测试或 CI 回归套件结果。",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "responses": {
          "201": {
            "description": "证据已接入并创建演进运行"
          },
          "400": {
            "description": "请求体不合法"
          },
          "401": {
            "description": "未授权"
          },
          "403": {
            "description": "需要操作员或更高角色"
          },
          "404": {
            "description": "项目不存在"
          },
          "409": {
            "description": "项目未验证"
          }
        }

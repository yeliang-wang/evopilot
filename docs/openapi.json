    "/api/v1/evidence/feedback": {
      "post": {
        "summary": "用户反馈证据接入",
        "description": "接收用户差评、投诉、满意度和人工标注，并与 traceId/sessionId 关联。",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "responses": {
          "201": {
            "description": "证据已接入并创建演进运行"
          },
          "400": {
            "description": "请求体不合法"
          },
          "401": {
            "description": "未授权"
          },
          "403": {
            "description": "需要操作员或更高角色"
          },
          "404": {
            "description": "项目不存在"
          },
          "409": {
            "description": "项目未验证"
          }
        }
      }
    },
    "/api/v1/runtimes": {
      "get": {
        "summary": "查询 EvoPilot 托管运行时锁定状态",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "responses": {
          "200": {
            "description": "运行时列表",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "data": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "properties": {
                          "id": {
                            "type": "string"
                          },
                          "name": {
                            "type": "string"
                          },
                          "implementation": {
                            "type": "string"
                          },
                          "role": {
                            "type": "string"
                          },
                          "version": {
                            "type": "string"
                          },
                          "image": {
                            "type": "string"
                          },
                          "digest": {
                            "type": "string"
                          },
                          "status": {
                            "type": "string",
                            "enum": [
                              "READY",
                              "MISSING",
                              "INCOMPLETE"
                            ]
                          },
                          "riskLevel": {
                            "type": "string",
                            "enum": [
                              "LOW",
                              "HIGH"
                            ]
                          }
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/supply-chain/reports": {
      "get": {
        "summary": "查询 EvoPilot 托管运行时锁定状态",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "responses": {
          "200": {
            "description": "运行时列表",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "data": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "properties": {
                          "id": {
                            "type": "string"
                          },
                          "name": {
                            "type": "string"
                          },
                          "implementation": {
                            "type": "string"
                          },
                          "role": {
                            "type": "string"
                          },
                          "version": {
                            "type": "string"
                          },
                          "image": {
                            "type": "string"
                          },
                          "digest": {
                            "type": "string"
                          },
                          "status": {
                            "type": "string",
                            "enum": [
                              "READY",
                              "MISSING",
                              "INCOMPLETE"
                            ]
                          },
                          "riskLevel": {
                            "type": "string",
                            "enum": [
                              "LOW",
                              "HIGH"
                            ]
                          }
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }

        ],
        "responses": {
          "200": {
            "description": "运行详情"
          },
          "404": {
            "description": "未找到运行记录"
          }
        }
      }
    },
    "/api/v1/reviews/{reviewId}/decision": {
      "post": {
        "summary": "提交评审决策",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "responses": {
          "200": {
            "description": "决策已记录"
          }
        }
      }
    },
    "/api/v1/deliveries/{deliveryId}/execute": {
      "post": {
        "summary": "执行交付",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "responses": {
          "200": {
            "description": "交付已执行"
          },
          "202": {
            "description": "Jenkins 流水线已触发"
          },
          "409": {
            "description": "需要用户确认"
          }
        }
      }
    },
    "/api/v1/audit": {
      "get": {
        "summary": "列出审计记录",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "responses": {
          "200": {
            "description": "审计记录"
          }
        }
      }
    },
    "/api/v1/metrics": {
      "get": {
        "summary": "Prometheus 风格指标",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "responses": {
          "200": {
            "description": "指标"
          }
        }
      }
    },
    "/api/v1/evidence/events": {
      "post": {
        "summary": "通用事件证据接入",
        "description": "接收 Agent、工具、LLM、RAG、路由、工作流等自定义证据，并创建演进运行。",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "responses": {
          "201": {
            "description": "证据已接入并创建演进运行"
          },
          "400": {
            "description": "请求体不合法"
          },
          "401": {
            "description": "未授权"
          },
          "403": {
            "description": "需要操作员或更高角色"
          },
          "404": {
            "description": "项目不存在"
          },
          "409": {
            "description": "项目未验证"
          }
        }
      }
    },
    "/api/v1/evidence/otlp/v1/traces": {
      "post": {
        "summary": "OpenTelemetry Trace 证据接入",
        "description": "接收 OTLP JSON Trace，将 span、traceId、service.name、耗时和 GenAI 属性转换为进化证据。",
        "security": [
          {
            "bearerAuth": []
          }

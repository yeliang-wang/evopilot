EVOPILOT_PORT=19876
EVOPILOT_DATA_ROOT=data/evopilot
EVOPILOT_DASHBOARD_ROOT=apps/dashboard
EVOPILOT_RUN_MODE=prod

# 生产模式默认值：
# - 必须配置 EVOPILOT_TOKENS 或 EVOPILOT_API_TOKEN。
# - 必须配置真实 LLM，且 LLM 失败不会模板兜底。
# - 不自动注册内置示例项目。
# - 不开放样例评测集。
# - 不允许模拟集成链路。
# 本地调试可使用：EVOPILOT_RUN_MODE=debug npm run server
# EVOPILOT_ALLOW_SAMPLE_DATA=false
# EVOPILOT_ALLOW_MOCK_INTEGRATIONS=false
# EVOPILOT_ALLOW_ANONYMOUS_ADMIN=false
# EVOPILOT_AUTO_REGISTER_PROFILE_PROJECT=false

# 推荐使用多 Token 格式：
# name:token:role，其中 role 可取 viewer、operator 或 admin。
EVOPILOT_TOKENS=admin:change-me-admin-token:admin,operator:change-me-operator-token:operator,viewer:change-me-viewer-token:viewer

# 向后兼容的单一管理员 Token。
# EVOPILOT_API_TOKEN=change-me

# 生产必填：LLM Gateway。未配置或调用失败时，prod 模式会直接阻断。
# 支持兼容 OpenAI Chat Completions 的模型服务，base URL 可填写到服务根路径或 /chat/completions。
# 默认会读取 data/evopilot/llm.env；也可用 EVOPILOT_LLM_ENV_FILE 指定其他明文配置文件。
# EVOPILOT_LLM_ENV_FILE=data/evopilot/llm.env
# EVOPILOT_LLM_PROVIDER_NAME=openai-compatible
# EVOPILOT_LLM_BASE_URL=https://llm.example.com/v1
# EVOPILOT_LLM_MODEL_NAME=your-model
# EVOPILOT_LLM_API_KEY=change-me
# EVOPILOT_LLM_TIMEOUT_SECONDS=300
# EVOPILOT_LLM_MAX_RETRIES=1
# EVOPILOT_LLM_DEFAULT_MAX_OUTPUT_TOKENS=8192
# EVOPILOT_LLM_MAX_OUTPUT_TOKENS=12288
# EVOPILOT_LLM_TEMPERATURE=0.2
# EVOPILOT_LLM_THINKING=disabled
# EVOPILOT_LLM_DEEP_THINKING=enabled
# EVOPILOT_LLM_METRICS_ENABLED=true
# EVOPILOT_LLM_METRICS_PATH=data/evopilot/llm-metrics.jsonl
# EVOPILOT_LLM_CONTEXT_COMPRESSION_ENABLED=true
# EVOPILOT_LLM_CONTEXT_MAX_PROMPT_CHARS=24000
# EVOPILOT_LLM_CONTEXT_HEAD_CHARS=12000
# EVOPILOT_LLM_CONTEXT_TAIL_CHARS=8000
EVOPILOT_REQUIRE_LLM=true
